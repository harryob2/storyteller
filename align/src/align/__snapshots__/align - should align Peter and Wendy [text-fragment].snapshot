#:~:text=rd.-,'%20
Text:  '
Audio: 

#:~:text='so%20a,.
Text:  'So are you a cowardy custard.
Audio: "'So are you a cowardly custard.'

#:~:text=rd.-,'%20
Text:  '
Audio: 

#:~:text='i'm%20n,.
Text:  'I'm not frightened.
Audio: "'I'm not frightened.'

#:~:text=ned.-,'%20
Text:  '
Audio: 

#:~:text='ne,.
